# Copia este archivo a .env y ajusta los valores.
# .env está gitignoreado — NUNCA commitear secretos reales.

NODE_ENV=development

# Servidor
PORT=3000
HOST=127.0.0.1
# Origen del frontend en dev (CORS + cookies)
WEB_ORIGIN=http://localhost:5173

# Base de datos (docker-compose por defecto)
DATABASE_URL=postgres://tableria:tableria_dev@localhost:5432/tableria

# Sesiones — genera valores propios: node -e "console.log(crypto.randomBytes(32).toString('base64'))"
SESSION_PEPPER=dev-only-change-me
# Clave AES-256-GCM para cifrar secretos (TOTP, tokens OAuth) — 32 bytes en base64
ENCRYPTION_KEY=3q2+7wAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Email (MailHog en dev)
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM=Tableria <no-reply@tableria.app>
