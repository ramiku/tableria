{
  "name": "tableria",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @tableria/db generate",
    "db:migrate": "pnpm --filter @tableria/db migrate",
    "db:seed": "pnpm --filter @tableria/db seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.0",
    "turbo": "^2.5.0",
    "typescript-eslint": "^8.24.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
